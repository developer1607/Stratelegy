# Copy to .env and fill in values (do not commit .env)
# cp .env.example .env

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=
APP_ID=stratelegy-insight
APP_BASE_URL=http://localhost:3000
CORS_ORIGINS=

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=stratelegy

# Initial admin (created on first run only, when users table is empty)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=

# Dev only — demo portal users for role testing (never runs when NODE_ENV=production)
SEED_DEMO_USERS=false
DEMO_USER_PASSWORD=Demo@123!

# Inbound email webhook — POST /api/webhooks/email?secret=...
EMAIL_WEBHOOK_SECRET=

# Outbound email (SMTP) — set MAIL_ENABLED=true to send real mail
MAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-mailbox@yourdomain.com
SMTP_PASS=your-app-password
SMTP_FROM="Stratelegy Insight <your-mailbox@yourdomain.com>"
SMTP_REPLY_TO=support@yourdomain.com
APP_NAME=Stratelegy Insight
SUPPORT_EMAIL=support@yourdomain.com

# Uploads directory (optional — defaults to ./data/uploads)
UPLOADS_DIR=

# Frontend (optional overrides)
VITE_APP_ID=
VITE_APP_BASE_URL=

# SkySwitch Telco API (PBX — credentials stay on server, never in the browser)
SKYSWITCH_ENABLED=true
SKYSWITCH_API_URL=https://api.skyswitch.com
SKYSWITCH_ACCOUNT_ID=
SKYSWITCH_CLIENT_ID=
SKYSWITCH_CLIENT_SECRET=
SKYSWITCH_USERNAME=
SKYSWITCH_PASSWORD=
SKYSWITCH_DEFAULT_DOMAIN=
SKYSWITCH_SCOPE=*
