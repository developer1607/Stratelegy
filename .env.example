# Copy to .env and fill in values (do not commit .env)
# cp .env.example .env

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# Production (NODE_ENV=production): JWT_SECRET and APP_BASE_URL are required.
# APP_BASE_URL must be your public HTTPS URL — used for CORS and email links.
JWT_SECRET=
APP_ID=stratelegy-insight
APP_BASE_URL=http://localhost:3000
# Set TRUST_PROXY=1 when running behind nginx or a load balancer (production).
TRUST_PROXY=
# Comma-separated origins when API and UI are on different domains (optional).
CORS_ORIGINS=

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=stratelegy

# Initial admin (created on first run only, when users table is empty)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=

# Dev only — demo portal users for role testing (never runs when NODE_ENV=production)
SEED_DEMO_USERS=false
DEMO_USER_PASSWORD=Demo@123!

# Inbound email webhook — POST /api/webhooks/email
# Auth: X-Webhook-Secret header, Authorization: Bearer <secret>, or ?secret= (legacy)
EMAIL_WEBHOOK_SECRET=

# Outbound email (SMTP) — set MAIL_ENABLED=true to send real mail
MAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-mailbox@yourdomain.com
SMTP_PASS=your-app-password
SMTP_FROM="Stratelegy Insight <your-mailbox@yourdomain.com>"
SMTP_REPLY_TO=support@yourdomain.com
APP_NAME=Stratelegy Insight
SUPPORT_EMAIL=support@yourdomain.com

# Uploads directory (optional — defaults to ./data/uploads)
UPLOADS_DIR=

# Frontend (optional overrides)
VITE_APP_ID=
VITE_APP_BASE_URL=

# SkySwitch Telco API (PBX — credentials stay on server, never in the browser)
# Set SKYSWITCH_ENABLED=false for local dev without network/API access.
SKYSWITCH_ENABLED=true
SKYSWITCH_API_URL=https://api.skyswitch.com
SKYSWITCH_ACCOUNT_ID=
SKYSWITCH_CLIENT_ID=
SKYSWITCH_CLIENT_SECRET=
SKYSWITCH_USERNAME=
SKYSWITCH_PASSWORD=
SKYSWITCH_DEFAULT_DOMAIN=
# OAuth scopes for the SkySwitch API user. Use * for all scopes, or list space-separated values.
# Portal PBX features need at minimum: pbx routing e911 messaging phone_number
# Call Logs also needs: log
# E911 Reports also needs: report
# Extensions UC config / entitlements also needs: uc_config entitlement
# Example (restricted): SKYSWITCH_SCOPE=pbx routing e911 messaging phone_number log report uc_config entitlement
SKYSWITCH_SCOPE=*
